# ── Server ──────────────────────────────────────
PORT=3000

# ── OpenAI ───────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Google Sheets ────────────────────────────────
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"

# ── WaSender (WhatsApp) ──────────────────────────
WASENDER_API_KEY=your_wasender_api_key

# ── Grow / Meshulam (payment webhooks) ───────────
GROW_WEBHOOK_KEY=your_grow_webhook_key
GROW_WEBHOOK_KEY_2=your_grow_standing_order_key

# ── Your WhatsApp number (to receive alerts) ─────
YOUR_WHATSAPP_NUMBER=+2348012345678

# ── Savings Split Rules (percentages, must add to 100) ──
SPLIT_SAVINGS=40
SPLIT_INVESTMENT=20
SPLIT_BUSINESS=20
SPLIT_PERSONAL=10
SPLIT_EMERGENCY=10
